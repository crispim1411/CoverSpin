<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="shortcut_auto"
        android:enabled="true"
        android:icon="@android:drawable/ic_popup_sync"
        android:shortcutShortLabel="@string/shortcut_auto_label"
        android:shortcutLongLabel="@string/shortcut_auto_label">
        <intent
            android:action="com.crispim.coverspin.ACTION_SET_MODE_AUTO"
            android:targetPackage="com.crispim.coverspin"
            android:targetClass="com.crispim.coverspin.MainActivity" />
    </shortcut>
    <shortcut
        android:shortcutId="shortcut_manual"
        android:enabled="true"
        android:icon="@android:drawable/ic_menu_rotate"
        android:shortcutShortLabel="@string/shortcut_manual_label"
        android:shortcutLongLabel="@string/shortcut_manual_label">
        <intent
            android:action="com.crispim.coverspin.ACTION_SET_MODE_MANUAL"
            android:targetPackage="com.crispim.coverspin"
            android:targetClass="com.crispim.coverspin.MainActivity" />
    </shortcut>
    <shortcut
        android:shortcutId="shortcut_disable_rotation"
        android:enabled="true"
        android:icon="@android:drawable/ic_lock_idle_lock"
        android:shortcutShortLabel="@string/shortcut_disable_rotation_label"
        android:shortcutLongLabel="@string/shortcut_disable_rotation_label">
        <intent
            android:action="com.crispim.coverspin.ACTION_DISABLE_ROTATION"
            android:targetPackage="com.crispim.coverspin"
            android:targetClass="com.crispim.coverspin.MainActivity" />
    </shortcut>
    <shortcut
        android:shortcutId="shortcut_disable_button"
        android:enabled="true"
        android:icon="@android:drawable/ic_menu_close_clear_cancel"
        android:shortcutShortLabel="@string/shortcut_disable_button_label"
        android:shortcutLongLabel="@string/shortcut_disable_button_label">
        <intent
            android:action="com.crispim.coverspin.ACTION_SET_MODE_OFF"
            android:targetPackage="com.crispim.coverspin"
            android:targetClass="com.crispim.coverspin.MainActivity" />
    </shortcut>
</shortcuts>